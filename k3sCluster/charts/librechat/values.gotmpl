{{ $values := readFile "./values.yaml" | fromYaml }}
{{ $mcpServers := $values.mcp_servers }}

librechat:
  configYamlContent: |
    version: 1.0.8
    mcpServers:
      {{- range $name, $value := $mcpServers }}
      "{{ $name }}":
        {{- if $value.command }}
        url: "http://mcp-server-{{ $name }}:8000/sse"
        {{- end }}
      {{- end }}
    mcpSettings:
      allowedDomains:
      {{- range $name, $value := $mcpServers }}
        - "http://mcp-server-{{ $name }}:8000"
      {{- end }}
    endpoints:
      custom:
      - name: "LiteLLM"
        apiKey: "${LITELLM_API_KEY}"
        baseURL: "http://litellm.litellm:4000/v1/"
        models:
          fetch: true
          default: ["gpt-5.4", "gpt-5.4-mini", "gpt-5.3-codex-spark"]
